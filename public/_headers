# Cache control headers for FluxUI
# Force no-cache for logo and favicon files to ensure immediate updates

/icon-only.svg*
  Cache-Control: public, max-age=0, must-revalidate

/icon-only.png*
  Cache-Control: public, max-age=0, must-revalidate

/apple-touch-icon.svg*
  Cache-Control: public, max-age=0, must-revalidate

/favicon.svg*
  Cache-Control: public, max-age=0, must-revalidate

/og-image.png*
  Cache-Control: public, max-age=0, must-revalidate

# Cache static assets for 1 year
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/static/*
  Cache-Control: public, max-age=31536000, immutable
